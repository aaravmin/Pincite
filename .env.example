# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# --- Supabase ---
# From your Supabase project settings. URL and anon key are safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key is server only. Never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Generation (Grok primary) ---
# xAI key. The API is OpenAI compatible at https://api.x.ai/v1
XAI_API_KEY=
GROK_MODEL=grok-4.3
# Cheaper tier for non core calls in later phases. Defaults to the flagship for safety.
GROK_FAST_MODEL=grok-4.3

# --- Generation fallback (Gemini) ---
# Used only when GENERATION_PROVIDER=gemini or Grok fails.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# grok or gemini
GENERATION_PROVIDER=grok

# --- Embeddings (Voyage) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-law-2

# --- Patent lookup (USPTO Open Data Portal) ---
# Free key from data.uspto.gov. Server side only.
USPTO_API_KEY=

# --- Prior art (Google BigQuery patents-public-data) ---
# Local: a filesystem path to the service-account JSON key (keep it OUTSIDE the repo).
GOOGLE_APPLICATION_CREDENTIALS=
# Production (Vercel and other hosts without a filesystem): paste the ENTIRE service-account
# JSON here instead. If set, it takes precedence over the file path above.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
